        <!-- Why PKCE -->
        <mxCell id="why-pkce" value="Why PKCE?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="720" width="100" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="pkce-reason1" value="• Prevents authorization code interception attacks" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="750" width="350" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="pkce-reason2" value="• No client_secret needed (safe for public clients)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="775" width="350" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="pkce-reason3" value="• code_verifier is single-use and never transmitted with auth request" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="800" width="450" height="20" as="geometry" />
        </mxCell>
        
        <!-- Used By -->
        <mxCell id="used-by" value="Used by:&#xa;• Mobile Apps (iOS/Android)&#xa;• Single Page Apps (SPAs)&#xa;• Desktop Applications&#xa;• Any public client" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
