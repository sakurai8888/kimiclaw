          <mxGeometry relative="1" as="geometry">
            <mxPoint x="545" y="540" as="sourcePoint" />
            <mxPoint x="315" y="540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Step 7: API Request -->
        <mxCell id="step7" value="7. API Request&#xa;(with Access Token)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" edge="1" parent="1">
